# Historical stats site identifier
export SERVER_NUMBER=1

# Docker
export POSTGRES_IMAGE=postgres:12-alpine

# Database
# Historical match data lives in PostgreSQL.
# Restore your existing dump into this database; the app does not read a data file directly from disk.
export HLL_DB_PASSWORD=
export HLL_DB_NAME=rcon
export HLL_DB_USER=rcon
export HLL_DB_HOST=localhost
export HLL_DB_HOST_PORT=5432
export HLL_DB_URL=postgresql://${HLL_DB_USER}:${HLL_DB_PASSWORD}@${HLL_DB_HOST}:${HLL_DB_HOST_PORT}/${HLL_DB_NAME}

# Public stats site
export HISTORY_ONLY=true
export ARCHIVE_SITE_NAME="CRCON Archive"
export PUBLIC_STATS_PORT=81
export PUBLIC_STATS_PORT_HTTPS=444
export RCONWEB_EXTERNAL_ADDRESS=7drstats.hllfrontline.com
