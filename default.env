# Historical archive-only deployment template

# Docker images
POSTGRES_IMAGE=postgres:12-alpine
BACKEND_DOCKER_REPOSITORY=cericmathey/hll_rcon_tool
FRONTEND_DOCKER_REPOSITORY=cericmathey/hll_rcon_tool_frontend
TAGGED_VERSION=latest

# Database
HLL_DB_PASSWORD=
HLL_DB_NAME=rcon
HLL_DB_USER=rcon
HLL_DB_HOST=postgres
HLL_DB_HOST_PORT=5432

# Public archive site
SERVER_NUMBER=1
ARCHIVE_SITE_NAME=CRCON Archive
PUBLIC_STATS_PORT=7010
PUBLIC_STATS_PORT_HTTPS=7011
RCONWEB_EXTERNAL_ADDRESS=7drstats.hllfrontline.com

# Backend
RCONWEB_API_SECRET=
NB_API_WORKERS=1
NB_API_THREADS=8
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=
SENTRY_DSN=
